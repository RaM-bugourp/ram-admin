.env.local
.env.*.local
*.pem
*.key
secrets/

# 系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# 测试覆盖率
htmlcov/
.coverage
.coverage.*
.cache
.pytest_cache/
.nyc_output/

